QWidget {
    background: {bg};
    color: {text_primary};
    font: 10pt "IBM Plex Sans";
}

QFrame, QGroupBox {
    background: {panel};
    border: 1px solid {border};
    border-radius: 6px;
}
QFrame#ButtonBox_Tools {
    background: {panel_alt};
    border: 1px solid {border};
    border-radius: 6px;
    padding: 2px 4px;
}

QGraphicsView {
    background: transparent;
    border: 0px;
}
QGraphicsView::viewport {
    background: transparent;
}

QToolButton, QPushButton {
    background: {panel_alt};
    border: 1px solid {border};
    border-radius: 4px;
    padding: 4px 8px;
    color: {text_primary};
}
QToolButton:hover, QPushButton:hover {
    background: {accent_hover};
}
QToolButton:pressed, QPushButton:pressed {
    background: {accent_active};
}
QToolButton:checked, QPushButton:checked {
    background: {accent};
    color: {text_primary};
}

QFrame#buttonBox_Playback {
    background: {panel_alt};
    border: 1px solid {border};
    border-radius: 12px;
    padding: 1px 3px;
}
QFrame#buttonBox_Playback QToolButton {
    background: transparent;
    border: 0px;
    padding: 1px 4px;
}
QFrame#buttonBox_Playback QToolButton:hover {
    background: {accent_hover};
    border-radius: 10px;
}
QFrame#buttonBox_Playback QToolButton:pressed {
    background: {accent_active};
    border-radius: 10px;
}
QFrame#buttonBox_Playback QToolButton:checked {
    background: {accent};
    border-radius: 10px;
}

QFrame#pillbox_SelectionTools,
QFrame#pillbox_NoteTools,
QFrame#pillbox_EditTools,
QFrame#pillbox_MetaTools,
QFrame#pillbox_TrackTools {
    background: {toolbox};
    border: 1px solid {border};
    border-radius: 12px;
    padding: 1px 3px;
}
QFrame#pillbox_SelectionTools QToolButton,
QFrame#pillbox_NoteTools QToolButton,
QFrame#pillbox_EditTools QToolButton,
QFrame#pillbox_MetaTools QToolButton,
QFrame#pillbox_TrackTools QToolButton {
    background: transparent;
    border: 0px;
    padding: 1px 4px;
}
QFrame#pillbox_SelectionTools QToolButton:hover,
QFrame#pillbox_NoteTools QToolButton:hover,
QFrame#pillbox_EditTools QToolButton:hover,
QFrame#pillbox_MetaTools QToolButton:hover,
QFrame#pillbox_TrackTools QToolButton:hover {
    background: {accent_hover};
    border-radius: 10px;
}
QFrame#pillbox_SelectionTools QToolButton:pressed,
QFrame#pillbox_NoteTools QToolButton:pressed,
QFrame#pillbox_EditTools QToolButton:pressed,
QFrame#pillbox_MetaTools QToolButton:pressed,
QFrame#pillbox_TrackTools QToolButton:pressed {
    background: {accent_active};
    border-radius: 10px;
}
QFrame#pillbox_SelectionTools QToolButton:checked,
QFrame#pillbox_NoteTools QToolButton:checked,
QFrame#pillbox_EditTools QToolButton:checked,
QFrame#pillbox_MetaTools QToolButton:checked,
QFrame#pillbox_TrackTools QToolButton:checked {
    background: {accent};
    border-radius: 10px;
}

QFrame#frame_volumeGroup {
    background: {panel_alt};
    border: 1px solid {border};
    border-radius: 12px;
    padding: 0px;
}
QFrame#frame_volumeGroup QLabel {
    background: transparent;
    border: 0px;
}

QFrame#frame_MetaDisplay {
    background: {bg};
    border: 1px solid {border};
    border-radius: 8px;
    padding: 2px 6px;
    min-height: 52px;
    font: 10pt "IBM Plex Sans";
}

QFrame#frame_3 {
    background: transparent;
    border: 0px;
    padding: 0px;
}
QFrame#frame_3 QRadioButton {
    background: transparent;
    border: 0px;
    padding: 2px 6px;
}
QFrame#frame_radioWrap {
    background: transparent;
    border: 0px;
}

QFrame#frame_TrackMetaControls {
    background: {panel_alt};
    border: 1px solid {border};
    border-radius: 4px;
}
QFrame#frame_TrackMetaControls QComboBox {
    background: {panel};
    border: 1px solid {border};
    border-radius: 3px;
    padding: 0px 4px;
    color: {text_primary};
    font: 8pt "IBM Plex Mono";
}
QFrame#frame_TrackMetaControls QToolButton[trackMetaFilter="true"] {
    background: {panel};
    border: 1px solid {border};
    border-radius: 2px;
    color: {text_secondary};
    padding: 0px;
}
QFrame#frame_TrackMetaControls QToolButton[trackMetaFilter="true"]:hover {
    background: {accent_hover};
    color: {text_primary};
}
QFrame#frame_TrackMetaControls QToolButton[trackMetaFilter="true"]:checked:hover {
    background: {accent_active};
    border-color: {accent};
    color: {text_primary};
}
QFrame#frame_TrackMetaControls QToolButton[trackMetaFilter="true"]:pressed {
    background: {accent_active};
    color: {text_primary};
}
QFrame#frame_TrackMetaControls QToolButton[trackMetaFilter="true"]:checked {
    background: {accent};
    border-color: {accent_active};
    color: {bg};
}
QFrame#frame_MetaDisplay QLabel {
    color: {text_secondary};
    background: transparent;
    border: 0px;
}
QFrame#frame_MetaDisplay QLabel#label_MetaTickValue,
QFrame#frame_MetaDisplay QLabel#label_MetaTimeValue,
QFrame#frame_MetaDisplay QLabel#label_MetaMeasureBeatValue,
QFrame#frame_MetaDisplay QLabel#label_MetaTempoValue,
QFrame#frame_MetaDisplay QLabel#label_MetaTimeSigValue,
QFrame#frame_MetaDisplay QLabel#label_MetaKeyValue {
    color: {text_primary};
    background: transparent;
    border: 0px;
}
QFrame#frame_MetaDisplay QLabel#label_MetaTimeValue {
    font: 20pt "IBM Plex Mono";
    padding-right: 8px;
}

QListView#listView_songTable {
    font: 10pt "IBM Plex Mono";
    background: {panel_alt};
    color: {text_primary};
    border: 1px solid {border};
    border-radius: 6px;
    outline: 0;
}
QListView#listView_songTable::item {
    padding: 3px 6px;
    border: 0px;
}
QListView#listView_songTable::item:hover {
    background: {panel};
    color: {text_primary};
}
QListView#listView_songTable::item:selected {
    background: {panel};
    color: {text_primary};
    font-weight: 600;
}
QListView#listView_songTable::item:selected:active,
QListView#listView_songTable::item:selected:!active {
    background: {panel};
    color: {text_primary};
    font-weight: 600;
}

QLineEdit#lineEdit_SongList_search {
    background: {panel};
    color: {text_primary};
    border: 1px solid {border};
    border-radius: 6px;
    padding: 4px 8px;
    selection-background-color: {accent};
    selection-color: {text_primary};
}
QLineEdit#lineEdit_SongList_search:focus {
    border: 1px solid {accent};
}
QLineEdit#lineEdit_SongList_search::placeholder {
    color: {text_secondary};
}

QLabel#label_SongList {
    color: {text_primary};
}

QGroupBox {
    margin-top: 16px;
    border: 1px solid {border};
}
QGroupBox#groupBox_Controls {
    background: transparent;
    border: 0px;
    margin-top: 0px;
}
QGroupBox#groupBox_Controls::title {
    padding: 0px;
    border: 0px;
}
QGroupBox QLabel {
    border: 0px;
    background: transparent;
}
QLabel#label_SongList {
    border: 0px;
    background: transparent;
}
QFrame#frame_SongList_label_searchbar {
    border: 0px;
    background: transparent;
    border-radius: 6px;
}
QGroupBox::title {
    subcontrol-origin: margin;
    subcontrol-position: top left;
    padding: 2px 8px;
    background: {panel_alt};
    border: 1px solid {border};
    border-bottom: none;
    border-top-left-radius: 4px;
    border-top-right-radius: 4px;
}

QSlider::groove:horizontal {
    background: {panel_alt};
    height: 6px;
    border-radius: 3px;
}
QSlider::handle:horizontal {
    background: {accent};
    width: 10px;
    margin: -3px 0;
    border-radius: 5px;
}

QSlider#masterVolumeSlider::groove:horizontal {
    background: transparent;
    height: 2px;
    border-radius: 1px;
    margin: 0px;
}
QSlider#masterVolumeSlider {
    padding: 0px;
    margin: 0px;
}
QSlider#masterVolumeSlider::handle:horizontal {
    background: {accent};
    width: 6px;
    margin: -12px 0;
    border-radius: 4px;
}

QScrollBar:vertical {
    background: {scroll_track};
    width: 10px;
    margin: 0;
}
QScrollBar::handle:vertical {
    background: {scroll_thumb};
    min-height: 20px;
    border-radius: 5px;
}
QScrollBar::add-line:vertical,
QScrollBar::sub-line:vertical {
    height: 0px;
}
QScrollBar::add-page:vertical,
QScrollBar::sub-page:vertical {
    background: none;
}
